PORT=8080
SECRETPRIVATEKEY=aaaaaaaaaaaaaaaaaaaaaaaaaaa

# JWT del foro: secret para verificar tokens (opcional si se usa FORUM_API_URL).
# FORUM_JWT_SECRET=

# Alternativa sin JWT: validar token llamando a la API del foro (ej. userData).
# Por defecto: https://underc0de.org/foro/extern/api.php
# FORUM_API_URL=https://underc0de.org/foro/extern/api.php

# MySQL del foro SMF — enriquece poster_time en /api/v1/forum/list y /forum/replies.
# Sin estas variables el proxy responde igual que api.php (sin fechas).
# FORUM_DB_HOST=
# FORUM_DB_PORT=3306
# FORUM_DB_USER=
# FORUM_DB_PASSWORD=
# FORUM_DB_NAME=
# FORUM_DB_PREFIX=smf_

DEFAULT_PAGE_COUNT= 10


ALLOWED_FILE_EXTENSIONS=.csv,.zip,.txt
FILE_SIZE=100000000

DB_NAME=
DB_USERNAME=
DB_PASSWORD=
DB_HOST=
DB_PORT=
NODE_ENV=development
# MercadoPago Configuration
# MP_BACK_URL: Redirección tras el pago. La app detecta /subscriptions/success en el WebView.
# MP_WEBHOOK_URL: MP notifica aquí (POST). Configurar en panel de MP. Ej: https://<api>/api/v1/webhook/mercadopago
MP_ACCESS_TOKEN=
MP_BACK_URL=https://underc0de.net/success
MP_WEBHOOK_URL=https://api.underc0de.net/api/v1/webhook/mercadopago
# MP_WEBHOOK_SECRET: Secret para validar firma x-signature (opcional). Obtenerlo en panel MP > Webhooks.
# MP_WEBHOOK_SECRET=
MERCADO_PAGO_COLLECTOR_EMAIL=info@underc0de.org
# Precio de suscripción en ARS (usado si la tabla Environments no existe)
MERCADO_PAGO_PRICE=3000

# Access token: duración en segundos (default 900 = 15 min). Refresh token: duración en días (default 7)
# ACCESS_TOKEN_EXPIRES_IN=900
# REFRESH_TOKEN_EXPIRES_DAYS=7

# --- Integración L2 Memories ↔ foro (rutas /api/v1/integrations/l2/*) ---
# Documentación: docs/partner-l2-forum-integration.md
# Habilitada por defecto si omitís la variable; desactivar con false o 0.
L2_PARTNER_INTEGRATION_ENABLED=true

# Opción recomendada: una API key por consumidor (JSON en una sola línea).
# L2memories debe enviar: Authorization: Bearer <valor> y X-Partner-Client-Id: l2memories
L2_PARTNER_API_KEYS={"l2memories":"l2memories-secret-key-underc0de'2026$%^&*"}

# Opción legacy (solo si NO usás L2_PARTNER_API_KEYS): un único secreto compartido.
# L2_PARTNER_INTEGRATION_SECRET=

# Lookup opcional en api.php: nombre de la acción (ej. usernameExists) para saber si el nick existe en el foro.
# Sin esto, username-status puede devolver forumMemberExists null (finalize con forumJwt igual funciona).
# FORUM_API_USERNAME_LOOKUP_ACTION=

# Si el foro exige autenticación server-to-server en el lookup, definila aquí (header X-Api-Key en el gateway).
# FORUM_API_SERVER_KEY=
