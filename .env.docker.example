# Copy to .env.docker for docker compose: cp .env.docker.example .env.docker

PORT=3002
URI=http://localhost:3002
API_PREFIX=/api/v1
NODE_ENV=development
DEFAULT_PAGE_COUNT=10

SECRETPRIVATEKEY=dev-secret-change-me

DB_HOST=postgres
DB_PORT=5432
DB_NAME=underc0deDashboard
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SSL=false

FIREBASE_DISABLED=true
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

APP_AUTH_SECRET=local-dev-app-auth-secret

# Optional — leave empty for local smoke tests without MP
MP_ACCESS_TOKEN=
MP_BACK_URL=http://localhost:3002/subscriptions/success
MP_WEBHOOK_URL=http://localhost:3002/api/v1/webhook/mercadopago
MERCADO_PAGO_PRICE=3000
